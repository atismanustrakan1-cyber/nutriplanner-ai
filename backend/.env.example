# Copy to backend/.env for local runs. On Vercel: Project → Settings →
# Environment Variables (same names). Redeploy after changing vars.

# OpenRouter — chat, scan-food, weekly meal plan: https://openrouter.ai/
OPENROUTER_API_KEY=

# USDA FoodData Central — food search (GET /api/food-search).
# Either name works; set one:
FOOD_API_KEY=
# USDA_API_KEY=
