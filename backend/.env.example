# Copy this file to .env and add your API keys.
#
# Vercel: add the same names in Project → Settings → Environment Variables
# (Production + Preview if you use previews). Redeploy after changing vars.
# Use FOOD_API_KEY below; USDA_API_KEY is also accepted for food search only.

# OpenRouter (AI chat + camera scan): https://openrouter.ai/
OPENROUTER_API_KEY=

# USDA FoodData Central (food search): https://fdc.nal.usda.gov/api-key-signup.html
FOOD_API_KEY=
